ASR_PROVIDER=doubao
ASR_MODE=fast

# Doubao streaming speech-to-text 2.0.
DOUBAO_APP_ID=your-doubao-app-id
DOUBAO_ACCESS_TOKEN=your-doubao-access-token
DOUBAO_RESOURCE_ID=volc.seedasr.sauc.duration

# Optional: use a separate app/token for Doubao file recognition with speaker diarization.
# The app/token must be granted the resource below, otherwise the API returns 45000030.
# DOUBAO_FILE_APP_ID=your-doubao-file-app-id
# DOUBAO_FILE_ACCESS_TOKEN=your-doubao-file-access-token
DOUBAO_FILE_RESOURCE_ID=volc.bigasr.auc_turbo
DOUBAO_END_WINDOW_SIZE=800
DOUBAO_FILE_TIMEOUT_SECONDS=300
# Leave these as 0 for automatic planning by interview duration.
DOUBAO_FILE_SEGMENT_SECONDS=0
DOUBAO_FILE_WORKERS=0
DOUBAO_FILE_MIN_SEGMENT_SECONDS=180
DOUBAO_FILE_MAX_SEGMENT_SECONDS=600
DOUBAO_FILE_MAX_WORKERS=6
DOUBAO_FILE_KEEP_SEGMENTS=false
REPORT_OUTPUT_DIR=D:\FS

RESUMESDK_URL=https://www.resumesdk.com/api/parse
RESUMESDK_UID=your-resumesdk-uid
RESUMESDK_PWD=your-resumesdk-pwd
RESUMESDK_TIMEOUT_SECONDS=30
RESUMESDK_NEED_AVATAR=0
RESUMESDK_HARD_TIMEOUT_SECONDS=65
RESUMESDK_MAX_FILE_MB=30

DASHSCOPE_API_KEY=your-dashscope-api-key

# Optional DashScope/Paraformer settings.
# DASHSCOPE_WORKSPACE=your-bailian-workspace-id
PARAFORMER_MODEL=paraformer-realtime-v2
PARAFORMER_LANGUAGE_HINTS=zh
PARAFORMER_MAX_SENTENCE_SILENCE=800

# DeepSeek semantic turn detection.
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
SEMANTIC_FINAL_ENABLED=true
SEMANTIC_FINAL_DEBOUNCE_MS=250
DEEPSEEK_TIMEOUT_SECONDS=12

# When true, the same semantic-final DeepSeek call also returns a short reply.
DEEPSEEK_REPLY_ENABLED=false
